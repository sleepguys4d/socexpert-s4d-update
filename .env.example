# ============================================================
#  SOC Xpert · Sec4data — configuração de ambiente
#  Copia este ficheiro para .env e preenche conforme o teu stack.
#    cp .env.example .env
# ============================================================

# Porta exposta no host
PORT=4000

# Origem dos dados:
#   true  → DEMO (dados simulados, arranca sem dependências)
#   false → LIVE (usa os conectores configurados abaixo)
DEMO_MODE=true

# CORS — em produção restringe ao teu domínio, ex: https://soc.sec4data.com
CORS_ORIGIN=*

# ──────────────── Wazuh ────────────────
# API do manager (saúde + agentes) — normalmente porta 55000
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
# Indexer / OpenSearch (pesquisa de alertas) — normalmente porta 9200
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=
WAZUH_ALERTS_INDEX=wazuh-alerts-*
# Aceitar certificados self-signed (laboratório). Em produção com TLS válido: false
WAZUH_INSECURE_TLS=true

# ──────────────── MISP ─────────────────
MISP_URL=
MISP_API_KEY=
MISP_INSECURE_TLS=true

# ─────────────── TheHive ───────────────
THEHIVE_URL=
THEHIVE_API_KEY=
THEHIVE_INSECURE_TLS=true

# ───────── Copilot (Anthropic) ─────────
# Sem chave, o Copilot funciona em modo fallback (respostas locais).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
